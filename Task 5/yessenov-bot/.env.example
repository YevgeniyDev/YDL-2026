# ─────────────────────────────────────────────────────────────────────────────
# Yessenov Foundation chatbot — environment configuration
# Copy this file to `.env` and fill in the real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# --- Client-provided LLM (OpenAI-compatible) ---
# Confirm the exact base URL, model name and key with the client before first run.
LLM_BASE_URL=https://llm.alem.ai/v1
CHAT_MODEL=gemma4
CHAT_API_KEY=replace-me-chat-key

# --- Client-provided embeddings (OpenAI-compatible) ---
# text-1024 => 1024-dimensional vectors. Must be multilingual (KK/RU/EN).
EMBED_BASE_URL=https://llm.alem.ai/v1/embeddings
EMBED_MODEL=text-1024
EMBED_API_KEY=replace-me-embed-key
EMBED_DIM=1024

# --- Context budget (the "small context window" constraint) ---
# Max input tokens we will pack into a single chat request (chunks + memory + question).
MAX_INPUT_TOKENS=4000

# --- Retrieval / anti-hallucination ---
TOP_K=4
# Cosine DISTANCE threshold (0=identical, 2=opposite). If the best retrieved chunk is
# farther than this, the bot returns the "I don't know -> contact a human" fallback.
# Calibrate after ingest against a few real questions.
# Measured: relevant queries 0.34-0.50, off-topic ~0.74 -> 0.60 separates them well.
RELEVANCE_MAX_DISTANCE=0.60

# --- Vector store backend: "numpy" (default, file-based) or "pgvector" ---
VECTOR_BACKEND=numpy
# Only used when VECTOR_BACKEND=pgvector:
DATABASE_URL=postgresql://user:pass@localhost:5432/yessenov

# --- Email (MailerSend) ---
MAILERSEND_API_KEY=replace-me-mailersend-key
# Send ONLY to your own inbox during development. From address is fixed by the sending domain.
ADMIN_EMAIL=your-personal@email.com
MAIL_FROM_EMAIL=info@app.commit.kz
MAIL_FROM_NAME=Yessenov Data Lab

# --- Foundation contact details (shown in the "I don't know" fallback) ---
CONTACT_EMAIL=info@yessenovfoundation.org
CONTACT_PHONE=+7 (771) 759-59-44
